{
  "$schema": "https://swc.rs/schema.json",
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": false
    },
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "target": "es2024",
    "keepClassNames": true
  },
  "module": {
    "type": "es6",
    "resolveFully": true
  },
  "minify": false
}
