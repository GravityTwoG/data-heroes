{
  "name": "data-heroes-notification-preferences-system",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "Marsel Abazbekov <marsel.ave@gmail.com>",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "docker compose up postgres -d && tsx watch --env-file=.env src/main.ts",
    "docker:dev": "docker compose up --build",
    "db:seed": "prisma db execute --file prisma/seed.sql",
    "db:reset": "prisma migrate reset --force",
    "build": "swc src scripts -d dist --source-maps --delete-dir-on-start --ignore '**/*.test.ts,**/*.d.ts'",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "typecheck": "tsc -b",
    "test": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --project unit --project e2e --coverage",
    "lint": "oxlint . --ignore-pattern dist --ignore-pattern node_modules --ignore-pattern dev-dist",
    "lint:fix": "oxlint --fix . --ignore-pattern dist --ignore-pattern node_modules --ignore-pattern dev-dist",
    "fmt": "oxfmt src",
    "fmt:check": "oxfmt --check src"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.41",
    "@testcontainers/postgresql": "^12.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "prisma": "^7.8.0",
    "testcontainers": "^12.0.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "volta": {
    "node": "24.13.0"
  },
  "engines": {
    "node": "24.13.0"
  }
}
