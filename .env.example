NODE_ENV=development # development/production

PORT=3000

# For local dev (app runs on host, postgres in docker)
DATABASE_URL=postgresql://pg-user:pg-password@localhost:6666/preferences-db
# For docker dev
# DATABASE_URL=postgresql://pg-user:pg-password@postgres:5432/preferences-db
DATABASE_POOL_CONNECTIONS_LIMIT=10 # number of connections in prisma connection pool
